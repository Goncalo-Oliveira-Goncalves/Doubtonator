NODE_ENV=development
PORT=3001
SESSION_SECRET=replace-with-a-long-random-secret
CORS_ORIGIN=http://localhost:5173

# Development: auto-assign this user on first request (same machine / browser = same canvas file).
# Must match userId rules: letters, digits, _, - only (e.g. user-1).
DEV_AUTO_USER_ID=user-1

# Optional: template copied into Backend/data/user-canvas/<userId>/workflow.mermaid on first open
# CANVAS_MERMAID_PATH=AI Workflow/workflow-map.mermaid

# Optional: override per-user canvas storage directory (default: Backend/data/user-canvas)
# USER_CANVAS_DATA_DIR=

# --- Supabase (add when wiring PostgreSQL / Auth / Storage) ---
# Project Settings → Database → URI (use pooler in serverless if recommended).
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# SUPABASE_URL=https://[ref].supabase.co
# SUPABASE_ANON_KEY=eyJ...   # public, for client-side with RLS
# SUPABASE_SERVICE_ROLE_KEY=eyJ...  # server only — never expose to browsers

# --- Railway ---
# PORT is injected automatically in production; do not hardcode in Railway.
